# Cloudinary Configuration
# Get these from your Cloudinary dashboard: https://cloudinary.com/console

# Your Cloudinary cloud name
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Upload preset (must be created in Cloudinary settings)
# Settings > Upload > Upload presets > Add upload preset
# Set it to "unsigned" for client-side uploads
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Optional: API Key (not required for unsigned uploads)
VITE_CLOUDINARY_API_KEY=

# API Configuration (optional overrides)
VITE_API_BASE_URL=https://dibakarb-dyslexia-backend.hf.space
VITE_API_TIMEOUT=60000
